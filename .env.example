# Пример переменных окружения для production
# Скопируйте в .env и заполните SECRET_KEY своим значением
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,93.77.182.91,nacpro-web-service.ru,www.nacpro-web-service.ru

# Необязательно: вынести SQLite и сгенерированные PDF/DOCX в каталог вне git (рекомендуется на сервере)
# Абсолютные пути; при первом запуске каталоги создаются автоматически
# SQLITE_DB_PATH=/var/lib/tkp-app/db.sqlite3
# TKP_OUTPUT_DIR=/var/lib/tkp-app/TKP_output
